      "xs":   { "value": "{radius.xs} + 6", "type": "borderRadius" },
      "sm":   { "value": "{radius.sm} + 6", "type": "borderRadius" },
      "md":   { "value": "{radius.md} + 6", "type": "borderRadius" },
      "lg":   { "value": "{radius.lg} + 6", "type": "borderRadius" },
      "xl":   { "value": "{radius.xl} + 6", "type": "borderRadius" },
      "full": { "value": "9999",            "type": "borderRadius" }
    }
